<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>2048 NEON | Neon Arcade</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* ===== RESET & BASE ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        :root {
            --neon-gold: #ffd700;
            --neon-cyan: #00ffff;
            --neon-pink: #ff00ff;
            --neon-green: #00ff88;
            --bg-dark: #0a0a0f;
            --grid-bg: rgba(20, 20, 30, 0.8);
            --tile-2: #00bcd4;
            --tile-4: #0097a7;
            --tile-8: #ff5722;
            --tile-16: #ff9800;
            --tile-32: #ffeb3b;
            --tile-64: #8bc34a;
            --tile-128: #4caf50;
            --tile-256: #2196f3;
            --tile-512: #3f51b5;
            --tile-1024: #9c27b0;
            --tile-2048: #ff4081;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: var(--bg-dark);
            color: white;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
            overflow-x: hidden;
        }
        
        /* ===== FOND ANIMÉ ===== */
        .bg-animation {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            pointer-events: none;
        }
        
        .particle {
            position: absolute;
            width: 4px;
            height: 4px;
            background: var(--neon-gold);
            border-radius: 50%;
            animation: float 15s infinite linear;
        }
        
        @keyframes float {
            0% {
                transform: translateY(100vh) translateX(0) rotate(0deg);
                opacity: 0;
            }
            10% {
                opacity: 1;
            }
            90% {
                opacity: 1;
            }
            100% {
                transform: translateY(-100px) translateX(100px) rotate(360deg);
                opacity: 0;
            }
        }
        
        /* ===== HEADER ===== */
        .header {
            text-align: center;
            margin-bottom: 30px;
            position: relative;
        }
        
        .neon-title {
            font-size: 48px;
            font-weight: 900;
            background: linear-gradient(90deg, var(--neon-gold), var(--neon-cyan), var(--neon-pink));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 20px rgba(255, 215, 0, 0.5);
            margin-bottom: 10px;
            letter-spacing: 2px;
        }
        
        .subtitle {
            color: var(--neon-cyan);
            font-size: 14px;
            letter-spacing: 3px;
            text-transform: uppercase;
        }
        
        .back-btn {
            position: absolute;
            left: 0;
            top: 50%;
            transform: translateY(-50%);
            color: var(--neon-gold);
            text-decoration: none;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 5px;
            transition: all 0.3s;
        }
        
        .back-btn:hover {
            color: var(--neon-cyan);
            transform: translateY(-50%) translateX(-5px);
        }
        
        /* ===== STATS ===== */
        .stats-container {
            display: flex;
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .stat-box {
            background: var(--grid-bg);
            border: 1px solid rgba(255, 215, 0, 0.3);
            border-radius: 15px;
            padding: 15px 25px;
            min-width: 150px;
            text-align: center;
            backdrop-filter: blur(10px);
            transition: all 0.3s;
        }
        
        .stat-box:hover {
            border-color: var(--neon-gold);
            box-shadow: 0 0 20px rgba(255, 215, 0, 0.2);
        }
        
        .stat-label {
            font-size: 12px;
            color: var(--neon-cyan);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }
        
        .stat-value {
            font-size: 36px;
            font-weight: 900;
            color: var(--neon-gold);
        }
        
        /* ===== GRILLE DE JEU ===== */
        .game-container {
            position: relative;
            margin-bottom: 30px;
        }
        
        .grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
            background: var(--grid-bg);
            border-radius: 20px;
            padding: 20px;
            border: 2px solid rgba(0, 255, 255, 0.1);
            box-shadow: 
                0 0 30px rgba(0, 0, 0, 0.5),
                inset 0 0 30px rgba(0, 255, 255, 0.05);
        }
        
        .cell {
            width: 100px;
            height: 100px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }
        
        .cell::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, 
                rgba(255, 255, 255, 0.1) 0%, 
                transparent 50%);
            border-radius: 15px;
        }
        
        .tile {
            position: absolute;
            width: 100px;
            height: 100px;
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            font-weight: 900;
            transition: all 0.2s ease-out;
            z-index: 2;
            box-shadow: 
                0 5px 15px rgba(0, 0, 0, 0.3),
                inset 0 1px 0 rgba(255, 255, 255, 0.2);
            user-select: none;
        }
        
        /* Couleurs des tuiles */
        .tile-2 { background: var(--tile-2); color: white; }
        .tile-4 { background: var(--tile-4); color: white; }
        .tile-8 { background: var(--tile-8); color: white; }
        .tile-16 { background: var(--tile-16); color: white; }
        .tile-32 { background: var(--tile-32); color: #333; }
        .tile-64 { background: var(--tile-64); color: #333; }
        .tile-128 { background: var(--tile-128); color: white; font-size: 28px; }
        .tile-256 { background: var(--tile-256); color: white; font-size: 28px; }
        .tile-512 { background: var(--tile-512); color: white; font-size: 26px; }
        .tile-1024 { background: var(--tile-1024); color: white; font-size: 24px; }
        .tile-2048 { 
            background: var(--tile-2048); 
            color: white; 
            font-size: 22px;
            animation: victory 2s infinite alternate;
        }
        
        @keyframes victory {
            0% { 
                box-shadow: 0 0 20px var(--tile-2048);
                transform: scale(1);
            }
            100% { 
                box-shadow: 0 0 40px var(--tile-2048), 0 0 60px var(--tile-2048);
                transform: scale(1.05);
            }
        }
        
        /* ===== MESSAGE ===== */
        .message {
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
        }
        
        .message-content {
            background: rgba(0, 0, 0, 0.5);
            padding: 15px 30px;
            border-radius: 50px;
            border: 1px solid var(--neon-gold);
            color: var(--neon-gold);
            font-size: 18px;
            font-weight: 600;
            letter-spacing: 1px;
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.5s;
        }
        
        .message-content.show {
            opacity: 1;
            transform: translateY(0);
        }
        
        /* ===== CONTROLES ===== */
        .controls {
            display: flex;
            gap: 15px;
            margin-bottom: 30px;
        }
        
        .btn {
            padding: 15px 30px;
            border: none;
            border-radius: 50px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 10px;
            letter-spacing: 1px;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, var(--neon-gold), #ffaa00);
            color: #000;
        }
        
        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(255, 215, 0, 0.3);
        }
        
        .btn-secondary {
            background: rgba(255, 255, 255, 0.1);
            color: var(--neon-cyan);
            border: 1px solid rgba(0, 255, 255, 0.3);
        }
        
        .btn-secondary:hover {
            background: rgba(0, 255, 255, 0.1);
            transform: translateY(-3px);
        }
        
        /* ===== INSTRUCTIONS ===== */
        .instructions {
            background: var(--grid-bg);
            border-radius: 15px;
            padding: 20px;
            margin-top: 20px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            max-width: 500px;
        }
        
        .instructions h3 {
            color: var(--neon-gold);
            margin-bottom: 15px;
            font-size: 18px;
        }
        
        .key {
            display: inline-block;
            background: rgba(255, 255, 255, 0.1);
            padding: 5px 10px;
            border-radius: 5px;
            margin: 0 5px;
            font-family: monospace;
        }
        
        /* ===== RESPONSIVE ===== */
        @media (max-width: 768px) {
            .neon-title { font-size: 36px; }
            .stats-container { flex-direction: column; align-items: center; }
            .stat-box { width: 100%; max-width: 300px; }
            .cell { width: 70px; height: 70px; }
            .tile { width: 70px; height: 70px; font-size: 24px; }
            .tile-128, .tile-256 { font-size: 20px; }
            .tile-512, .tile-1024 { font-size: 18px; }
            .tile-2048 { font-size: 16px; }
            .controls { flex-wrap: wrap; justify-content: center; }
        }
        
        /* ===== ANIMATIONS ===== */
        @keyframes pop {
            0% { transform: scale(0); opacity: 0; }
            70% { transform: scale(1.1); opacity: 1; }
            100% { transform: scale(1); opacity: 1; }
        }
        
        @keyframes merge {
            0% { transform: scale(1); }
            50% { transform: scale(1.2); }
            100% { transform: scale(1); }
        }
        
        .tile.new {
            animation: pop 0.3s ease-out;
        }
        
        .tile.merge {
            animation: merge 0.4s ease-out;
        }
    </style>
</head>
<body>
    <!-- Fond animé avec particules -->
    <div class="bg-animation" id="bgAnimation"></div>
    
    <!-- En-tête -->
    <div class="header">
        <a href="index.html" class="back-btn">
            <i class="fas fa-arrow-left"></i> RETOUR
        </a>
        <h1 class="neon-title">2048 NEON</h1>
        <p class="subtitle">Fusionnez jusqu'à 2048 !</p>
    </div>
    
    <!-- Statistiques -->
    <div class="stats-container">
        <div class="stat-box">
            <div class="stat-label">Score</div>
            <div class="stat-value" id="score">0</div>
        </div>
        <div class="stat-box">
            <div class="stat-label">Meilleur Score</div>
            <div class="stat-value" id="best">0</div>
        </div>
        <div class="stat-box">
            <div class="stat-label">Tuiles</div>
            <div class="stat-value" id="tiles">2</div>
        </div>
    </div>
    
    <!-- Message -->
    <div class="message">
        <div class="message-content" id="message">Utilisez les flèches pour jouer !</div>
    </div>
    
    <!-- Grille de jeu -->
    <div class="game-container">
        <div class="grid" id="grid">
            <!-- Les cellules seront générées par JavaScript -->
        </div>
    </div>
    
    <!-- Contrôles -->
    <div class="controls">
        <button class="btn btn-primary" onclick="resetGame()">
            <i class="fas fa-redo"></i> NOUVELLE PARTIE
        </button>
        <button class="btn btn-secondary" onclick="undoMove()">
            <i class="fas fa-undo"></i> ANNULER
        </button>
        <button class="btn btn-secondary" onclick="toggleInstructions()">
            <i class="fas fa-info-circle"></i> AIDE
        </button>
    </div>
    
    <!-- Instructions (cachées par défaut) -->
    <div class="instructions" id="instructions" style="display: none;">
        <h3><i class="fas fa-gamepad"></i> COMMENT JOUER</h3>
        <p style="margin-bottom: 10px; color: #ccc;">
            <strong>Objectif :</strong> Atteindre la tuile <span style="color: var(--tile-2048); font-weight: bold;">2048</span> en fusionnant des tuiles identiques.
        </p>
        <p style="margin-bottom: 10px; color: #ccc;">
            <strong>Contrôles :</strong><br>
            • Clavier : <span class="key">↑</span> <span class="key">↓</span> <span class="key">←</span> <span class="key">→</span><br>
            • Mobile : Swipe dans la direction souhaitée
        </p>
        <p style="color: #ccc;">
            <strong>Conseil :</strong> Essayez de garder votre tuile la plus élevée dans un coin !
        </p>
    </div>
    
    <!-- Pied de page -->
    <footer style="margin-top: 40px; color: #666; font-size: 12px; text-align: center;">
        <p>Neon Arcade © 2024 | 2048 NEON Edition</p>
    </footer>

    <script>
        // ===== CONFIGURATION =====
        const GRID_SIZE = 4;
        let grid = [];
        let score = 0;
        let bestScore = localStorage.getItem('2048-best') || 0;
        let gameOver = false;
        let previousState = null;
        
        // ===== ÉLÉMENTS DOM =====
        const gridElement = document.getElementById('grid');
        const scoreElement = document.getElementById('score');
        const bestElement = document.getElementById('best');
        const tilesElement = document.getElementById('tiles');
        const messageElement = document.getElementById('message');
        const instructionsElement = document.getElementById('instructions');
        
        // ===== INITIALISATION =====
        function init() {
            // Créer la grille vide
            grid = Array(GRID_SIZE).fill().map(() => Array(GRID_SIZE).fill(0));
            
            // Réinitialiser le score
            score = 0;
            gameOver = false;
            previousState = null;
            
            // Mettre à jour l'affichage
            scoreElement.textContent = '0';
            bestElement.textContent = bestScore;
            tilesElement.textContent = '2';
            
            // Cacher le message
            hideMessage();
            
            // Générer la grille HTML
            renderGrid();
            
            // Ajouter 2 tuiles initiales
            addRandomTile();
            addRandomTile();
            
            // Mettre à jour l'affichage
            updateTilesCount();
            
            // Créer les particules de fond
            createParticles();
        }
        
        // ===== RENDU DE LA GRILLE =====
        function renderGrid() {
            gridElement.innerHTML = '';
            
            for (let row = 0; row < GRID_SIZE; row++) {
                for (let col = 0; col < GRID_SIZE; col++) {
                    // Créer une cellule
                    const cell = document.createElement('div');
                    cell.className = 'cell';
                    cell.dataset.row = row;
                    cell.dataset.col = col;
                    
                    // Ajouter la tuile si elle existe
                    const value = grid[row][col];
                    if (value > 0) {
                        const tile = document.createElement('div');
                        tile.className = `tile tile-${value}`;
                        tile.textContent = value;
                        tile.dataset.value = value;
                        cell.appendChild(tile);
                    }
                    
                    gridElement.appendChild(cell);
                }
            }
        }
        
        // ===== AJOUTER UNE TUILE ALÉATOIRE =====
        function addRandomTile() {
            // Trouver toutes les cellules vides
            const emptyCells = [];
            for (let row = 0; row < GRID_SIZE; row++) {
                for (let col = 0; col < GRID_SIZE; col++) {
                    if (grid[row][col] === 0) {
                        emptyCells.push({ row, col });
                    }
                }
            }
            
            // Si pas de cellules vides, retourner
            if (emptyCells.length === 0) return;
            
            // Choisir une cellule aléatoire
            const { row, col } = emptyCells[Math.floor(Math.random() * emptyCells.length)];
            
            // 90% de chance d'avoir un 2, 10% un 4
            grid[row][col] = Math.random() < 0.9 ? 2 : 4;
            
            // Ajouter l'animation "new"
            const tile = gridElement.children[row * GRID_SIZE + col].querySelector('.tile');
            if (tile) {
                tile.classList.add('new');
                setTimeout(() => tile.classList.remove('new'), 300);
            }
            
            // Effet sonore visuel
            createParticleEffect(col * 115 + 57.5, row * 115 + 57.5, grid[row][col]);
        }
        
        // ===== DÉPLACEMENT =====
        function move(direction) {
            if (gameOver) return;
            
            // Sauvegarder l'état précédent
            saveState();
            
            let moved = false;
            
            // Copie de la grille pour comparaison
            const oldGrid = grid.map(row => [...row]);
            
            // Déplacer selon la direction
            switch(direction) {
                case 'up':
                    for (let col = 0; col < GRID_SIZE; col++) {
                        const column = [];
                        for (let row = 0; row < GRID_SIZE; row++) {
                            column.push(grid[row][col]);
                        }
                        const newColumn = slideAndMerge(column);
                        for (let row = 0; row < GRID_SIZE; row++) {
                            if (grid[row][col] !== newColumn[row]) moved = true;
                            grid[row][col] = newColumn[row];
                        }
                    }
                    break;
                    
                case 'down':
                    for (let col = 0; col < GRID_SIZE; col++) {
                        const column = [];
                        for (let row = GRID_SIZE - 1; row >= 0; row--) {
                            column.push(grid[row][col]);
                        }
                        const newColumn = slideAndMerge(column);
                        for (let row = 0; row < GRID_SIZE; row++) {
                            if (grid[GRID_SIZE - 1 - row][col] !== newColumn[row]) moved = true;
                            grid[GRID_SIZE - 1 - row][col] = newColumn[row];
                        }
                    }
                    break;
                    
                case 'left':
                    for (let row = 0; row < GRID_SIZE; row++) {
                        const newRow = slideAndMerge(grid[row]);
                        for (let col = 0; col < GRID_SIZE; col++) {
                            if (grid[row][col] !== newRow[col]) moved = true;
                            grid[row][col] = newRow[col];
                        }
                    }
                    break;
                    
                case 'right':
                    for (let row = 0; row < GRID_SIZE; row++) {
                        const reversed = [...grid[row]].reverse();
                        const newRow = slideAndMerge(reversed).reverse();
                        for (let col = 0; col < GRID_SIZE; col++) {
                            if (grid[row][col] !== newRow[col]) moved = true;
                            grid[row][col] = newRow[col];
                        }
                    }
                    break;
            }
            
            // Si un mouvement a eu lieu
            if (moved) {
                // Ajouter une nouvelle tuile
                addRandomTile();
                
                // Mettre à jour l'affichage
                renderGrid();
                updateScore();
                updateTilesCount();
                
                // Vérifier la victoire
                if (checkWin()) {
                    showMessage("🎉 VICTOIRE ! Vous avez atteint 2048 !", "victory");
                    gameOver = true;
                }
                // Vérifier la défaite
                else if (checkGameOver()) {
                    showMessage("💀 GAME OVER ! Plus de mouvements possibles.", "gameover");
                    gameOver = true;
                }
            }
        }
        
        // ===== FONCTION DE FUSION =====
        function slideAndMerge(line) {
            // Filtrer les zéros
            let filtered = line.filter(val => val !== 0);
            
            // Fusionner les tuiles identiques
            for (let i = 0; i < filtered.length - 1; i++) {
                if (filtered[i] === filtered[i + 1]) {
                    filtered[i] *= 2;
                    score += filtered[i];
                    filtered.splice(i + 1, 1);
                    
                    // Animation de fusion
                    setTimeout(() => {
                        const tiles = document.querySelectorAll('.tile');
                        tiles.forEach(tile => {
                            if (parseInt(tile.textContent) === filtered[i]) {
                                tile.classList.add('merge');
                                setTimeout(() => tile.classList.remove('merge'), 400);
                            }
                        });
                    }, 100);
                }
            }
            
            // Remplir avec des zéros
            while (filtered.length < GRID_SIZE) {
                filtered.push(0);
            }
            
            return filtered;
        }
        
        // ===== VÉRIFICATIONS =====
        function checkWin() {
            for (let row = 0; row < GRID_SIZE; row++) {
                for (let col = 0; col < GRID_SIZE; col++) {
                    if (grid[row][col] === 2048) {
                        return true;
                    }
                }
            }
            return false;
        }
        
        function checkGameOver() {
            // Vérifier s'il reste des cases vides
            for (let row = 0; row < GRID_SIZE; row++) {
                for (let col = 0; col < GRID_SIZE; col++) {
                    if (grid[row][col] === 0) {
                        return false;
                    }
                }
            }
            
            // Vérifier les fusions possibles
            for (let row = 0; row < GRID_SIZE; row++) {
                for (let col = 0; col < GRID_SIZE - 1; col++) {
                    if (grid[row][col] === grid[row][col + 1]) {
                        return false;
                    }
                }
            }
            
            for (let col = 0; col < GRID_SIZE; col++) {
                for (let row = 0; row < GRID_SIZE - 1; row++) {
                    if (grid[row][col] === grid[row + 1][col]) {
                        return false;
                    }
                }
            }
            
            return true;
        }
        
        // ===== GESTION DU SCORE =====
        function updateScore() {
            scoreElement.textContent = score;
            
            // Mettre à jour le meilleur score
            if (score > bestScore) {
                bestScore = score;
                bestElement.textContent = bestScore;
                localStorage.setItem('2048-best', bestScore);
                
                // Animation pour le nouveau record
                bestElement.style.transform = 'scale(1.2)';
                bestElement.style.color = 'var(--neon-pink)';
                setTimeout(() => {
                    bestElement.style.transform = 'scale(1)';
                    bestElement.style.color = 'var(--neon-gold)';
                }, 500);
            }
        }
        
        function updateTilesCount() {
            let count = 0;
            for (let row = 0; row < GRID_SIZE; row++) {
                for (let col = 0; col < GRID_SIZE; col++) {
                    if (grid[row][col] > 0) count++;
                }
            }
            tilesElement.textContent = count;
        }
        
        // ===== SAUVEGARDE D'ÉTAT =====
        function saveState() {
            previousState = {
                grid: grid.map(row => [...row]),
                score: score
            };
        }
        
        function undoMove() {
            if (!previousState || gameOver) return;
            
            grid = previousState.grid.map(row => [...row]);
            score = previousState.score;
            previousState = null;
            
            scoreElement.textContent = score;
            renderGrid();
            updateTilesCount();
            hideMessage();
            gameOver = false;
        }
        
        // ===== MESSAGES =====
        function showMessage(text, type = 'info') {
            messageElement.textContent = text;
            messageElement.classList.add('show');
            
            // Changer la couleur selon le type
            if (type === 'victory') {
                messageElement.style.color = 'var(--neon-green)';
                messageElement.style.borderColor = 'var(--neon-green)';
            } else if (type === 'gameover') {
                messageElement.style.color = 'var(--neon-pink)';
                messageElement.style.borderColor = 'var(--neon-pink)';
            } else {
                messageElement.style.color = 'var(--neon-gold)';
                messageElement.style.borderColor = 'var(--neon-gold)';
            }
            
            // Cacher après 3 secondes (sauf pour game over/victoire)
            if (type === 'info') {
                setTimeout(hideMessage, 3000);
            }
        }
        
        function hideMessage() {
            messageElement.classList.remove('show');
        }
        
        // ===== INSTRUCTIONS =====
        function toggleInstructions() {
            if (instructionsElement.style.display === 'none') {
                instructionsElement.style.display = 'block';
                showMessage('Instructions affichées', 'info');
            } else {
                instructionsElement.style.display = 'none';
                showMessage('Instructions cachées', 'info');
            }
        }
        
        // ===== EFFETS VISUELS =====
        function createParticles() {
            const bgAnimation = document.getElementById('bgAnimation');
            bgAnimation.innerHTML = '';
            
            for (let i = 0; i < 50; i++) {
                const particle = document.createElement('div');
                particle.className = 'particle';
                
                // Position aléatoire
                particle.style.left = `${Math.random() * 100}%`;
                particle.style.top = `${Math.random() * 100}%`;
                
                // Taille aléatoire
                const size = Math.random() * 3 + 1;
                particle.style.width = `${size}px`;
                particle.style.height = `${size}px`;
                
                // Couleur aléatoire
                const colors = ['#ffd700', '#00ffff', '#ff00ff', '#00ff88'];
                particle.style.background = colors[Math.floor(Math.random() * colors.length)];
                
                // Délai d'animation
                particle.style.animationDelay = `${Math.random() * 15}s`;
                
                bgAnimation.appendChild(particle);
            }
        }
        
        function createParticleEffect(x, y, value) {
            const colors = {
                2: '#00bcd4', 4: '#0097a7', 8: '#ff5722',
                16: '#ff9800', 32: '#ffeb3b', 64: '#8bc34a',
                128: '#4caf50', 256: '#2196f3', 512: '#3f51b5',
                1024: '#9c27b0', 2048: '#ff4081'
            };
            
            const color = colors[value] || '#ffffff';
            
            for (let i = 0; i < 8; i++) {
                const particle = document.createElement('div');
                particle.style.cssText = `
                    position: absolute;
                    width: 8px;
                    height: 8px;
                    background: ${color};
                    border-radius: 50%;
                    left: ${x}px;
                    top: ${y}px;
                    pointer-events: none;
                    z-index: 100;
                `;
                
                document.querySelector('.game-container').appendChild(particle);
                
                // Animation
                const angle = Math.random() * Math.PI * 2;
                const speed = Math.random() * 30 + 20;
                const dx = Math.cos(angle) * speed;
                const dy = Math.sin(angle) * speed;
                
                let opacity = 1;
                const animate = () => {
                    opacity -= 0.03;
                    particle.style.opacity = opacity;
                    particle.style.transform = `translate(${dx}px, ${dy}px) scale(${opacity})`;
                    
                    if (opacity > 0) {
                        requestAnimationFrame(animate);
                    } else {
                        particle.remove();
                    }
                };
                requestAnimationFrame(animate);
            }
        }
        
        // ===== CONTRÔLES CLAVIER =====
        document.addEventListener('keydown', (e) => {
            if (gameOver && e.key !== 'Enter') return;
            
            switch(e.key) {
                case 'ArrowUp':
                    e.preventDefault();
                    move('up');
                    break;
                case 'ArrowDown':
                    e.preventDefault();
                    move('down');
                    break;
                case 'ArrowLeft':
                    e.preventDefault();
                    move('left');
                    break;
                case 'ArrowRight':
                    e.preventDefault();
                    move('right');
                    break;
                case 'r':
                case 'R':
                    resetGame();
                    break;
                case 'u':
                case 'U':
                    undoMove();
                    break;
            }
        });
        
        // ===== CONTRÔLES TACTILES =====
        let touchStartX = 0;
        let touchStartY = 0;
        
        document.addEventListener('touchstart', (e) => {
            touchStartX = e.touches[0].clientX;
            touchStartY = e.touches[0].clientY;
        }, { passive: true });
        
        document.addEventListener('touchend', (e) => {
            if (!touchStartX || !touchStartY) return;
            
            const touchEndX = e.changedTouches[0].clientX;
            const touchEndY = e.changedTouches[0].clientY;
            
            const dx = touchEndX - touchStartX;
            const dy = touchEndY - touchStartY;
            
            // Seuil de détection (40px)
            if (Math.abs(dx) > Math.abs(dy)) {
                // Mouvement horizontal
                if (Math.abs(dx) > 40) {
                    if (dx > 0) {
                        move('right');
                    } else {
                        move('left');
                    }
                }
            } else {
                // Mouvement vertical
                if (Math.abs(dy) > 40) {
                    if (dy > 0) {
                        move('down');
                    } else {
                        move('up');
                    }
                }
            }
            
            touchStartX = 0;
            touchStartY = 0;
        }, { passive: true });
        
        // ===== FONCTIONS PUBLIQUES =====
        function resetGame() {
            init();
            showMessage('Nouvelle partie ! Bonne chance !', 'info');
        }
        
        // ===== DÉMARRAGE =====
        init();
        showMessage('Utilisez les flèches ou swipez pour jouer !', 'info');
    </script>
</body>
</html>
